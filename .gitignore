# ===============================================================
# SECURITY GATEKEEPER: PROTECT CANVAS API CREDENTIALS
# ===============================================================
.env
.env.*
!.env.example
.gemini_session_history

# ===============================================================
# EXW COURSE ARCHITECTURE: TRACK MASTER ASSETS
# ===============================================================
# Ensure Master Context and Markdown are NEVER ignored
!GEMINI.md
!*.md

# Track specific instructional directories
!modules/
!02_COURSES/
!MODULE_RESOURCES/
!HOME_PAGES/
!docs/
!assets/
!_layouts/

# ===============================================================
# HTML MANAGEMENT: PREVENT "MUCK" WHILE SAVING TEMPLATES
# ===============================================================
# Ignore generic HTML output from the Markdown-to-Canvas build process
html-builds/
*.html

# WHITE-LIST: Keep specific Master Templates and Course Overviews
!awc-template.html
!awc-announcement.html
!UNIFIED_MASTER_SYLLABUS.html
!UNIFIED_HOME_PAGE.html
!index.html

# Fall 2026 Syllabus Architecture
!EXW101/Fall_2026/EXW101_Syllabus_Fall2026.html
!EXW245/Fall_2026/EXW245_Syllabus_Fall2026.html
!EXW265/Fall_2026/EXW265_Syllabus_Fall2026.html

# Module Resource Components (The SSoT & Universal Logic)
!MODULE_RESOURCES/**/*.html
!02_COURSES/**/*.html
!docs/**/*.html
!assets/templates/*.html
!Master-Library/Legacy-Assets/HTML-Templates/*.html
!_layouts/*.html

# ===============================================================
# SYSTEM & IDE JUNK (CLEANED)
# ===============================================================
# Node / Dependency noise
node_modules/
logs
*.log
npm-debug.log*
.node_repl_history
.cache/

# IDE Configuration & Temp Files
.vscode/
.idea/
*.swp
*.bak
*.tmp
~$*
.DS_Store
Thumbs.db
desktop.ini

# Build / Distribution Folders
dist/
out/
.next/